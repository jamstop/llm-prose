#!/usr/bin/env bash
# Convenience shim for running deslop from the repo root. The tool itself is a
# single stdlib-only file bundled in the skill (no install, no venv); this just
# forwards to it with the system python3.
set -euo pipefail
root="$(cd "$(dirname "$0")/.." && pwd)"
exec python3 "$root/skills/comment-bloat-review/scripts/deslop.py" "$@"

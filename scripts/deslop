#!/usr/bin/env bash
# Thin wrapper around the deslop Python tool. Prefers the tool's local venv
# (tools/deslop/.venv) and falls back to whatever python3 has it installed.
set -euo pipefail
root="$(cd "$(dirname "$0")/.." && pwd)"
venv_py="$root/tools/deslop/.venv/bin/python"
if [ -x "$venv_py" ]; then
  exec "$venv_py" -m deslop "$@"
fi
exec python3 -m deslop "$@"
